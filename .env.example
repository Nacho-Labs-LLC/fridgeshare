# HTTP port
PORT=4173

# Required for public deployments: restricts board create/delete to this token
# SELFHOST_ADMIN_TOKEN=change-me

# Data directories (defaults shown; override if you change your volume mount)
# FRIDGE_DATA_DIR=server/data/fridges
# FRIDGE_UPLOAD_DIR=server/data/uploads
# BOARD_DIRECTORY_PATH=server/data/boards.json

# Upload size limit in bytes (default: 4 MiB)
# FRIDGE_MAX_UPLOAD_BYTES=4194304

# Write rate limiting per client per board
# FRIDGE_WRITE_RATE_WINDOW_MS=60000
# FRIDGE_WRITE_RATE_LIMIT=60
